{
  "bot-account": {
    "username": "AkshitAFKBot",
    "password": "",
    "type": "offline"
  },
  "server": {
    "ip": "BPSfriends.aternos.me",
    "port": 11917,
    "version": "1.21.11",
    "dynip": "",
    "use-srv": true
  },
  "position": {
    "enabled": false,
    "x": 0,
    "y": 0,
    "z": 0
  },
  "utils": {
    "auto-auth": {
      "enabled": false,
      "password": ""
    },
    "anti-afk": {
      "enabled": true,
      "log-actions": true,
      "summary-interval": 300,
      "random-actions": {
        "enabled": true,
        "move": {
          "chance": 1,
          "min-delay": 3,
          "max-delay": 7,
          "min-duration": 0.35,
          "max-duration": 0.8
        },
        "jump": {
          "chance": 0.75,
          "min-delay": 5,
          "max-delay": 12,
          "min-duration": 0.15,
          "max-duration": 0.35
        },
        "crouch": {
          "chance": 0.5,
          "min-delay": 10,
          "max-delay": 20,
          "min-duration": 0.5,
          "max-duration": 1.5
        },
        "punch": {
          "chance": 0.65,
          "min-delay": 7,
          "max-delay": 16
        }
      }
    },
    "connection-routing": {
      "public-dns": true,
      "srv-fallback": true,
      "dns-timeout": 4
    },
    "readiness-probe": {
      "interval": 3,
      "tcp-timeout": 3,
      "dns-refresh": 15,
      "spawn-timeout": 20,
      "retry-after-disconnect": 3
    },
    "connection-watchdog": {
      "enabled": true,
      "check-interval": 20,
      "max-packet-silence": 120,
      "tcp-keepalive-delay": 30
    },
    "server-status-watchdog": {
      "enabled": true,
      "interval": 30,
      "timeout": 8,
      "max-failures": 3,
      "startup-grace": 15
    },
    "chat-messages": {
      "enabled": false,
      "repeat": false,
      "repeat-delay": 60,
      "messages": []
    },
    "chat-log": true,
    "auto-reconnect": true,
    "auto-reconnect-delay": 3000,
    "keepalive-timeout": 120
  }
}
